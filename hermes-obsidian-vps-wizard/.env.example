# Windows-local reverse SSH and verification values.
WINDOWS_USERNAME=ExampleUser
OBSIDIAN_LOCAL_PORT=27124
OBSIDIAN_API_KEY=<REPLACE_ME>
VPS_HOST=vps.example.net
VPS_SSH_PORT=22
VPS_USER=hermes
VPS_REMOTE_PORT=37124
SSH_EXE_PATH=C:\Windows\System32\OpenSSH\ssh.exe
SSH_LOG_PATH=%USERPROFILE%\hermes-obsidian-reverse-ssh.log
